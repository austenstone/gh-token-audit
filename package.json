{
  "name": "gh-token-audit",
  "version": "0.1.0",
  "description": "Statically audit GITHUB_TOKEN permissions across an Enterprise/org before flipping the default to read-only. Finds workflows that silently rely on the permissive default and would break.",
  "type": "module",
  "bin": {
    "gh-token-audit": "dist/cli.mjs"
  },
  "files": [
    "dist",
    "gh-token-audit",
    "action.yml"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --test"
  },
  "keywords": [
    "github",
    "actions",
    "github-token",
    "permissions",
    "security",
    "least-privilege",
    "audit",
    "gh-extension"
  ],
  "author": "Austen Stone",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@octokit/rest": "^22.0.0",
    "commander": "^14.0.1",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^24.9.2",
    "esbuild": "^0.25.11",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true
  }
}
